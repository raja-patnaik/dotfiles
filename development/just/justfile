# Justfile - Command runner for development tasks
# https://github.com/casey/just

# Set shell for Windows compatibility
set windows-shell := ["powershell.exe", "-NoLogo", "-Command"]
set shell := ["bash", "-uc"]

# Default recipe to display help
default:
  @just --list

# Variables
export EDITOR := env_var_or_default("EDITOR", "nvim")
export PAGER := env_var_or_default("PAGER", "less")

# Dotfiles installation directory
dotfiles_dir := env_var_or_default("DOTFILES_DIR", justfile_directory())

# OS detection
os := os()
arch := arch()
home := env_var("HOME")

# ============================================================================
# Installation
# ============================================================================

# Install dotfiles (auto-detect OS)
install:
  #!/usr/bin/env bash
  set -euo pipefail
  cd {{ dotfiles_dir }}
  if [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "cygwin" ]] || [[ "$OSTYPE" == "win32" ]]; then
    echo "Running Windows installation..."
    powershell.exe -ExecutionPolicy Bypass -File install.ps1
  else
    echo "Running Unix/Linux/macOS installation..."
    ./install.sh
  fi

# Install specific components
install-component component:
  #!/usr/bin/env bash
  cd {{ dotfiles_dir }}
  ./install.sh --only {{ component }}

# Dry run installation
install-dry-run:
  #!/usr/bin/env bash
  cd {{ dotfiles_dir }}
  ./install.sh --dry-run

# ============================================================================
# Updates
# ============================================================================

# Update all packages
update:
  @echo "Updating packages..."
  @just update-{{ os }}

# Update macOS packages
update-macos:
  brew update && brew upgrade
  brew bundle install --file={{ dotfiles_dir }}/packages/Brewfile

# Update Linux packages
update-linux:
  #!/usr/bin/env bash
  if command -v apt-get &>/dev/null; then
    sudo apt-get update && sudo apt-get upgrade -y
  fi
  if command -v brew &>/dev/null; then
    brew update && brew upgrade
  fi

# Update Windows packages
update-windows:
  scoop update && scoop update *
  winget upgrade --all

# Update language tools
update-tools:
  @echo "Updating development tools..."
  @just update-rust
  @just update-node
  @just update-python

# Update Rust toolchain and crates
update-rust:
  rustup update
  cargo install-update -a

# Update Node packages
update-node:
  npm update -g
  pnpm update -g

# Update Python packages
update-python:
  pip install --upgrade pip setuptools wheel
  pipx upgrade-all

# ============================================================================
# Backup and Restore
# ============================================================================

# Backup current configurations
backup name="manual":
  #!/usr/bin/env bash
  set -euo pipefail
  backup_dir="$HOME/.dotfiles-backups/{{ name }}-$(date +%Y%m%d-%H%M%S)"
  mkdir -p "$backup_dir"

  echo "Backing up to $backup_dir..."

  # List of files/directories to backup
  configs=(
    ".zshrc" ".bashrc" ".gitconfig"
    ".tmux.conf" ".wezterm.lua"
    ".config/nvim" ".config/starship.toml"
    ".config/lazygit" ".config/atuin"
  )

  for config in "${configs[@]}"; do
    if [[ -e "$HOME/$config" ]]; then
      cp -r "$HOME/$config" "$backup_dir/" || true
    fi
  done

  echo "Backup completed: $backup_dir"

# List available backups
list-backups:
  @ls -la ~/.dotfiles-backups/ 2>/dev/null || echo "No backups found"

# Restore from backup
restore backup:
  #!/usr/bin/env bash
  set -euo pipefail
  if [[ ! -d "$HOME/.dotfiles-backups/{{ backup }}" ]]; then
    echo "Backup not found: {{ backup }}"
    exit 1
  fi
  cp -r "$HOME/.dotfiles-backups/{{ backup }}"/* "$HOME/"
  echo "Restored from backup: {{ backup }}"

# ============================================================================
# Git Operations
# ============================================================================

# Git status
status:
  @git status -sb

# Commit all changes
commit message:
  git add -A
  git commit -m "{{ message }}"

# Push to remote
push:
  git push origin $(git branch --show-current)

# Pull latest changes
pull:
  git pull --rebase

# Sync fork with upstream
sync-fork:
  git fetch upstream
  git checkout main
  git merge upstream/main
  git push origin main

# ============================================================================
# Development
# ============================================================================

# Run pre-commit hooks
lint:
  pre-commit run --all-files

# Install pre-commit hooks
install-hooks:
  pre-commit install
  pre-commit install --hook-type commit-msg

# Format all code
format:
  @echo "Formatting code..."
  @just format-python
  @just format-js
  @just format-shell

# Format Python code
format-python:
  black .
  isort .
  ruff --fix .

# Format JavaScript/TypeScript
format-js:
  prettier --write "**/*.{js,jsx,ts,tsx,json,css,md}"

# Format shell scripts
format-shell:
  shfmt -w -i 2 -ci -bn **/*.sh

# ============================================================================
# Testing
# ============================================================================

# Test shell configurations
test-shell:
  @echo "Testing shell configurations..."
  bash -n {{ dotfiles_dir }}/shell/bash/.bashrc
  zsh -n {{ dotfiles_dir }}/shell/zsh/.zshrc

# Validate configurations
validate:
  @echo "Validating configurations..."
  @just validate-yaml
  @just validate-json
  @just validate-toml

# Validate YAML files
validate-yaml:
  yamllint .

# Validate JSON files
validate-json:
  find . -name "*.json" -exec jq empty {} \;

# Validate TOML files
validate-toml:
  find . -name "*.toml" -exec toml-cli validate {} \;

# ============================================================================
# System Information
# ============================================================================

# Show system information
info:
  @echo "System Information:"
  @echo "  OS: {{ os }}"
  @echo "  Arch: {{ arch }}"
  @echo "  Home: {{ home }}"
  @echo "  Shell: $SHELL"
  @echo "  Dotfiles: {{ dotfiles_dir }}"

# Check tool versions
versions:
  @echo "Tool Versions:"
  @command -v git &>/dev/null && git --version || echo "  git: not installed"
  @command -v node &>/dev/null && echo "  node: $(node --version)" || echo "  node: not installed"
  @command -v python &>/dev/null && echo "  python: $(python --version 2>&1)" || echo "  python: not installed"
  @command -v rust &>/dev/null && echo "  rust: $(rustc --version)" || echo "  rust: not installed"
  @command -v go &>/dev/null && echo "  go: $(go version)" || echo "  go: not installed"

# Health check
health:
  @echo "Running health checks..."
  @just check-links
  @just check-commands

# Check for broken symlinks
check-links:
  @find ~ -maxdepth 3 -type l ! -exec test -e {} \; -print 2>/dev/null | grep -v "Permission denied" || echo "No broken symlinks found"

# Check required commands
check-commands:
  #!/usr/bin/env bash
  commands=(git curl wget nvim tmux zsh)
  missing=()
  for cmd in "${commands[@]}"; do
    if ! command -v "$cmd" &>/dev/null; then
      missing+=("$cmd")
    fi
  done
  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Missing commands: ${missing[*]}"
  else
    echo "All required commands are installed"
  fi

# ============================================================================
# Cleanup
# ============================================================================

# Clean temporary files and caches
clean:
  @echo "Cleaning temporary files..."
  @just clean-cache
  @just clean-logs

# Clean cache directories
clean-cache:
  rm -rf ~/.cache/nvim
  rm -rf ~/.cache/pip
  rm -rf ~/.npm/_cacache

# Clean log files
clean-logs:
  find ~ -name "*.log" -type f -mtime +7 -delete

# Remove all dotfiles symlinks
uninstall:
  @echo "Removing dotfiles symlinks..."
  @echo "This would remove all symlinks. Implementation needed based on OS."

# ============================================================================
# Docker
# ============================================================================

# Build dotfiles Docker image
docker-build:
  docker build -t dotfiles:latest .

# Run dotfiles in Docker
docker-run:
  docker run -it --rm -v {{ dotfiles_dir }}:/dotfiles dotfiles:latest

# ============================================================================
# Help
# ============================================================================

# Show detailed help
help:
  @echo "Dotfiles Management with Just"
  @echo ""
  @echo "Installation:"
  @echo "  just install              - Install dotfiles"
  @echo "  just install-component    - Install specific component"
  @echo "  just install-dry-run      - Preview installation"
  @echo ""
  @echo "Updates:"
  @echo "  just update              - Update all packages"
  @echo "  just update-tools        - Update development tools"
  @echo ""
  @echo "Development:"
  @echo "  just lint                - Run linters"
  @echo "  just format              - Format code"
  @echo "  just test-shell          - Test shell configs"
  @echo ""
  @echo "Maintenance:"
  @echo "  just backup              - Backup configurations"
  @echo "  just clean               - Clean temporary files"
  @echo "  just health              - Run health checks"
  @echo ""
  @just --list